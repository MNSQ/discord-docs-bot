# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Discord ─────────────────────────────────────────────────────────────────
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Optional: default guild ID used by `npm run register` for guild-scoped commands
DISCORD_GUILD_ID=

# ── Ollama gateway (local LLM) ───────────────────────────────────────────────
# Set this to your Cloudflare tunnel URL in Vercel, e.g. https://xxxx.trycloudflare.com
# For local gateway testing: http://localhost:8787
OLLAMA_BASE_URL=

# Shared secret between Vercel and the local gateway (npm run gateway)
OLLAMA_GATEWAY_SECRET=

# Optional: defaults to qwen3:4b
OLLAMA_MODEL=qwen3:4b

# ── App ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed app — used to generate dashboard links in Discord messages
NEXT_PUBLIC_APP_URL=
